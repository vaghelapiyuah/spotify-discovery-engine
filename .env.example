# Copy to .env and fill in. The Anthropic SDK reads ANTHROPIC_API_KEY automatically.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# Model used for the AI analysis layer. Defaults to claude-opus-4-8.
# For high-volume runs you may switch to claude-haiku-4-5 or claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-opus-4-8

# Max parallel analysis workers (threads)
ENGINE_WORKERS=6
